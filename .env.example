PORT=8000
NODE_ENV=development
API_PREFIX=/api/v1

# Database (for Docker use DB_HOST=db)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=installops
DB_USER=installops
DB_PASS=

# Required: long random string for session signing (min 16 chars)
SESSION_SECRET=

# Optional
# CORS_ORIGIN=*
# CORS_CREDENTIALS=false
# ENABLE_BACKUP_SCHEDULER=false
